---
import Layout from '../../layouts/Layout.astro';
import { getAllSeguros } from '../../data/seguros';
import ContactForm from '../../components/Contato/FormContact';
import CoverageCarousel from '../../components/Seguros/CoverageCarousel';

export async function getStaticPaths() {
  const seguros = getAllSeguros();
  return seguros.map(seguro => ({
    params: { slug: seguro.slug },
    props: { seguro }
  }));
}

const { seguro } = Astro.props;
---

<Layout title={`${seguro.title} | Maia Seguros`}>
  <div class="w-full bg-white">

    {/* Breadcrumb */}
    <div class="flex flex-row bg-[#f5f5f5] px-2 py-4 font-[NotoSansLight] tracking-tight text-sm gap-2 sm:px-8">
      <span>Home</span>
      <span>/</span>
      <h1 class="font-[NotoSansRegular]">{seguro.title}</h1>
    </div>

    {/* Hero Section */}
    <div class="relative w-full bg-black">
      <div class="relative z-10 max-w-6xl mx-auto flex flex-row items-center gap-8 p-4 md:p-12 text-white hidden sm:flex">
        
        {/* Hero Text */}
        <div class="flex-1 flex flex-col gap-2 md:gap-4 text-center md:text-left">
          <h1 class="text-3xl md:text-5xl font-[NotoSansRegular] tracking-tight">{seguro.title}</h1>
          <p class="text-sm md:text-lg font-[NotoSansLight]">{seguro.subtitle}</p>
          <h2 class="text-lg md:text-2xl font-[NotoSansBold]">{seguro.cta}</h2>
          <a href="#contato" class="max-w-max inline-block mt-2 md:mt-4 bg-white text-[#0A1F7A] font-[NotoSansBold] py-1 px-4 rounded-sm text-center hover:bg-gray-100 transition">
            Faça sua cotação
          </a>
        </div>

        {/* Hero Image */}
        <div class="flex-1 w-full h-48 md:h-80 rounded-xl overflow-hidden mt-4 md:mt-0">
          <img src={seguro.heroImage} alt={seguro.title} class="w-full h-full object-cover"/>
        </div>

      </div>
    </div>

    <div class="relative w-full h-full flex flex-col p-4 gap-2 bg-black sm:hidden">
      <div class="relative z-10 max-w-6xl mx-auto h-full flex flex-col justify-center text-white gap-2">
        <h1 class="text-md md:text-5xl tracking-tightest font-[NotoSansRegular]">{seguro.title}</h1>
        <img src={seguro.heroImage} alt={seguro.title} class="w-full h-full object-cover aspect-video rounded-xl" />
        <h1 class="text-lg md:text-5xl tracking-tight font-[NotoSansBold]">{seguro.subtitle}</h1>
        <p class="text-sm tracking-tight font-[NotoSansLight]">{seguro.cta}</p>
        <div class="text-lg md:text-5xl tracking-tight font-[NotoSansBold] bg-white text-center rounded-sm py-1 max-w-max px-2">
           <a href="#contato" class="max-w-max inline-block  px-2 py-1 bg-white text-[#0A1F7A] font-[NotoSansBold]  rounded-sm text-center hover:bg-gray-100 transition">
            Faça sua cotação
          </a>
        </div>
      </div>
    </div>

    {/* Content Section */}
    <div class="max-w-6xl mx-auto px-4 md:px-6 py-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">

        {/* Description + Benefits */}
        <div>
          <h2 class="text-2xl md:text-3xl font-[MMC] text-[#0A1F7A] mb-4">Sobre este Seguro</h2>
          <p class="text-gray-700 font-[NotoSansLight] leading-relaxed mb-6">{seguro.description}</p>

          <h3 class="text-xl md:text-2xl font-[MMC] text-[#0A1F7A] mb-4">Benefícios</h3>
          <ul class="space-y-3">
            {seguro.benefits.map((benefit: string) => (
              <li class="flex items-start gap-3">
                <svg class="text-green-500 flex-shrink-0 mt-1" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                  <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                <span class="text-gray-700 font-[NotoSansLight]">{benefit}</span>
              </li>
            ))}
          </ul>
        </div>

        {/* Coverage Carousel */}
        <div>
          <CoverageCarousel coverage={seguro.coverage} client:load />
        </div>

      </div>

      {/* Contact Form */}
      <div id="contato" class="mt-12">
        <ContactForm client:load />
      </div>
    </div>

  </div>
</Layout>
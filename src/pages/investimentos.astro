---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Seguros Americanos em Dólar | Maia Seguros">
  <div class="w-full bg-white">

    {/* Breadcrumb */}
    <div class="flex flex-row bg-[#f5f5f5] px-2 py-4 font-[NotoSansLight] tracking-tight gap-2 text-sm sm:px-8">
      <span>Home</span>
      <span>/</span>
      <h1 class="font-[NotoSansRegular]">Investimentos em Dólar</h1>
    </div>

    {/* Hero Section */}
    <div class="relative w-full bg-black">
      <div class="relative z-10 max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-6 p-4 md:p-12 text-white">

        {/* Hero Text */}
        <div class="flex-1 flex flex-col gap-2 md:gap-4">
          <h1 class="text-md md:text-5xl font-[NotoSansRegular] tracking-tightest">Seguros Americanos em Dólar</h1>
          <p class="text-sm md:text-lg font-[NotoSansLight]">Diversifique em dólar e garanta eficiência fiscal</p>
          <h2 class="text-lg md:text-3xl font-[NotoSansBold]">Proteja seu patrimônio com inteligência</h2>
          <a href="/contato" class="inline-block max-w-max mt-2 md:mt-4 bg-white text-[#0A1F7A] font-[NotoSansBold] py-1 px-4 rounded-sm hover:bg-gray-100 transition">
            Agendar Consultoria
          </a>
        </div>

        {/* Hero Image */}
        <div class="flex-1 w-full h-48 md:h-96 rounded-xl overflow-hidden">
          <img src="/photos/02.webp" alt="Investimentos" class="w-full h-full object-cover"/>
        </div>

      </div>
    </div>

    {/* Content Section */}
    <div class="max-w-6xl mx-auto px-6 py-8">

      {/* Riscos */}
      <div class="mb-12">
        <h2 class="text-2xl md:text-3xl font-[MMC] text-[#0A1F7A] mb-4">Seu Patrimônio está 100% em Real?</h2>
        <p class="text-gray-700 font-[NotoSansLight] leading-relaxed mb-8">
          Risco cambial, inflação e instabilidade política podem corroer seu dinheiro ao longo do tempo.
        </p>

        <div class="grid md:grid-cols-3 gap-6 mb-8">
          {/* Cards Riscos */}
          <div class="relative overflow-hidden rounded-xl group">
            <img src="/photos/seguros-page/01.jpg" alt="Risco Cambial" class="w-full h-48 object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-4">
              <div>
                <h3 class="text-lg font-[NotoSansBold] text-white mb-1">Risco Cambial</h3>
                <p class="text-sm font-[NotoSansLight] text-white/90">Desvalorização do real</p>
              </div>
            </div>
          </div>
          <div class="relative overflow-hidden rounded-xl group">
            <img src="/photos/seguros-page/02.webp" alt="Inflação" class="w-full h-48 object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-4">
              <div>
                <h3 class="text-lg font-[NotoSansBold] text-white mb-1">Inflação</h3>
                <p class="text-sm font-[NotoSansLight] text-white/90">Perda de poder de compra</p>
              </div>
            </div>
          </div>
          <div class="relative overflow-hidden rounded-xl group">
            <img src="/photos/seguros-page/planejamento-financeiro.jpeg" alt="Instabilidade" class="w-full h-48 object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-4">
              <div>
                <h3 class="text-lg font-[NotoSansBold] text-white mb-1">Instabilidade Política</h3>
                <p class="text-sm font-[NotoSansLight] text-white/90">Incertezas no mercado</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* A Solução */}
      <div class="bg-[#0A1F7A] rounded-xl p-8 text-white mb-12">
        <h2 class="text-2xl md:text-3xl font-[MMC] mb-6">Seguro Americano com Formação de Reserva</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div>
            <h3 class="text-lg font-[NotoSansBold] mb-2">Proteger em Dólar</h3>
            <p class="font-[NotoSansLight] text-sm">Mantenha seu poder de compra protegido da volatilidade do real</p>
          </div>
          <div>
            <h3 class="text-lg font-[NotoSansBold] mb-2">Eficiência Fiscal</h3>
            <p class="font-[NotoSansLight] text-sm">Rendimentos acumulam tax-deferred, sem IR anual</p>
          </div>
          <div>
            <h3 class="text-lg font-[NotoSansBold] mb-2">Sucessão Facilitada</h3>
            <p class="font-[NotoSansLight] text-sm">Herança direta para herdeiros, sem inventário</p>
          </div>
        </div>
      </div>

      {/* Histórico do Dólar */}
      <div class="mb-12">
        <h2 class="text-2xl md:text-3xl font-[MMC] text-[#0A1F7A] mb-6">Dólar desde o Plano Real</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-gray-50 p-6 rounded-xl">
            <h3 class="text-lg font-[NotoSansBold] text-[#0A1F7A] mb-4">Histórico de Cotações</h3>
            <ul class="space-y-2">
              <li class="flex justify-between p-2 bg-white rounded">
                <span class="font-[NotoSansRegular] text-sm">Jun/1994</span>
                <span class="font-[NotoSansBold] text-sm">R$ 1,00</span>
              </li>
              <li class="flex justify-between p-2 bg-white rounded">
                <span class="font-[NotoSansRegular] text-sm">Set/2002</span>
                <span class="font-[NotoSansBold] text-sm">R$ 3,90</span>
              </li>
              <li class="flex justify-between p-2 bg-white rounded">
                <span class="font-[NotoSansRegular] text-sm">Out/2020</span>
                <span class="font-[NotoSansBold] text-sm">R$ 5,70</span>
              </li>
              <li class="flex justify-between p-2 bg-white rounded">
                <span class="font-[NotoSansRegular] text-sm">Abr/2024</span>
                <span class="font-[NotoSansBold] text-sm">R$ 5,18</span>
              </li>
            </ul>
          </div>

          <div class="relative overflow-hidden rounded-xl">
            <img src="/photos/seguros-page/blindagem-patrimonial-1.webp" alt="Dólar" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 to-transparent flex items-end p-6">
              <div>
                <h3 class="text-lg font-[NotoSansBold] text-white mb-2">Desvalorização Histórica</h3>
                <p class="text-sm font-[NotoSansLight] text-white/90">
                  Desde 1994, o dólar acumulou valorização expressiva. Ajustado pela inflação, estaria próximo a R$ 5,70.
                </p>
                <p class="text-xs font-[NotoSansLight] text-white/70 mt-2">Fonte: Austin Rating / Poder 360</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Comparativo Table */}
      <div class="mb-12">
        <h2 class="text-2xl md:text-3xl font-[MMC] text-[#0A1F7A] mb-6 text-center">Seguro em Dólar X VGBL</h2>
        <div class="overflow-x-auto rounded-xl border border-gray-200">
          <table class="w-full">
            <thead>
              <tr class="bg-[#0A1F7A] text-white">
                <th class="p-4 text-left font-[NotoSansBold] text-sm">Característica</th>
                <th class="p-4 text-center font-[NotoSansBold] text-sm">Seguro em USD</th>
                <th class="p-4 text-center font-[NotoSansBold] text-sm">VGBL</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b">
                <td class="p-4 font-[NotoSansRegular] text-sm">Moeda</td>
                <td class="p-4 text-center bg-green-50 font-[NotoSansBold] text-green-700 text-sm">Dólar (USD)</td>
                <td class="p-4 text-center bg-orange-50 font-[NotoSansRegular] text-sm">Real (BRL)</td>
              </tr>
              <tr class="border-b">
                <td class="p-4 font-[NotoSansRegular] text-sm">Proteção Cambial</td>
                <td class="p-4 text-center bg-green-50 font-[NotoSansBold] text-green-700 text-sm">Sim</td>
                <td class="p-4 text-center bg-orange-50 font-[NotoSansRegular] text-sm">Não</td>
              </tr>
              <tr class="border-b">
                <td class="p-4 font-[NotoSansRegular] text-sm">Tributação</td>
                <td class="p-4 text-center bg-green-50 font-[NotoSansBold] text-green-700 text-sm">Tax-deferred</td>
                <td class="p-4 text-center bg-orange-50 font-[NotoSansRegular] text-sm">Regressiva (até 10%)</td>
              </tr>
              <tr class="border-b">
                <td class="p-4 font-[NotoSansRegular] text-sm">Sucessão</td>
                <td class="p-4 text-center bg-green-50 font-[NotoSansBold] text-green-700 text-sm">Sem inventário</td>
                <td class="p-4 text-center bg-orange-50 font-[NotoSansRegular] text-sm">Sem inventário</td>
              </tr>
              <tr class="border-b">
                <td class="p-4 font-[NotoSansRegular] text-sm">Risco Brasil</td>
                <td class="p-4 text-center bg-green-50 font-[NotoSansBold] text-green-700 text-sm">Não exposto</td>
                <td class="p-4 text-center bg-orange-50 font-[NotoSansRegular] text-sm">Exposto</td>
              </tr>
              <tr>
                <td class="p-4 font-[NotoSansRegular] text-sm">Proteção Patrimonial</td>
                <td class="p-4 text-center bg-green-50 font-[NotoSansBold] text-green-700 text-sm">Alta</td>
                <td class="p-4 text-center bg-orange-50 font-[NotoSansRegular] text-sm">Média</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      {/* Para quem é */}
      <div class="bg-[#e84620] rounded-xl p-8 text-white mb-12">
        <h2 class="text-2xl md:text-3xl font-[MMC] mb-6 text-center">Para quem é?</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="text-center">
            <p class="font-[NotoSansRegular]">Patrimônio acima de R$ 500K</p>
          </div>
          <div class="text-center">
            <p class="font-[NotoSansRegular]">Exposição internacional</p>
          </div>
          <div class="text-center">
            <p class="font-[NotoSansRegular]">Proteção para a família</p>
          </div>
        </div>
      </div>

      {/* CTA */}
      <div class="text-center">
        <h2 class="text-2xl md:text-3xl font-[MMC] text-[#0A1F7A] mb-4">Proteja seu patrimônio com inteligência</h2>
        <a href="/contato" class="inline-block bg-[#0A1F7A] text-white px-8 py-3 rounded-full font-[NotoSansRegular] hover:bg-[#e84620] transition-colors">
          Agendar Consultoria
        </a>
      </div>

    </div>
  </div>
</Layout>
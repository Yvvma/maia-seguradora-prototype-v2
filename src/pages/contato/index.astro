---
import Layout from '../../layouts/Layout.astro';
import FormContainer from '../../components/Contato/FormContact';
---

<Layout title="Contato | Maia Seguros">
  <div class="w-full bg-white">

    {/* Breadcrumb */}
    <div class="flex flex-row bg-[#f5f5f5] px-2 py-4 font-[NotoSansLight] tracking-tight gap-2 text-sm md:px-8">
      <span>Home</span>
      <span>/</span>
      <h1 class="font-[NotoSansRegular]">Contato</h1>
    </div>

    {/* Hero Section */}
    <div class="relative w-full h-full flex flex-col p-4 gap-2 bg-black">
      <div class="relative z-10 max-w-6xl mx-auto h-full flex flex-col justify-center text-white gap-2">
        <h1 class="text-md md:text-5xl tracking-tightest font-[NotoSansRegular]">Fale Conosco</h1>
        <img src="/photos/seguros-page/should-couples-buy-separate-insurance-policies.jpg" alt="Contato" class="w-full h-full object-cover aspect-video rounded-xl" />
        <h1 class="text-lg md:text-5xl tracking-tight font-[NotoSansBold]">Estamos prontos para ajudar você</h1>
        <p class="text-sm tracking-tight font-[NotoSansLight]">Entre em contato e descubra as melhores soluções para proteger seu patrimônio</p>
        <div class="text-lg md:text-5xl tracking-tight font-[NotoSansBold] bg-white text-center rounded-sm py-1 max-w-max px-2">
          <a href="#formulario" class="text-[#0A1F7A] tracking-tight text-sm">
            Enviar Mensagem
          </a>
        </div>
      </div>
    </div>

    {/* Content Section */}
    <div class="max-w-6xl mx-auto px-6 py-8">
      
      {/* Informações de Contato */}
      <div class="grid md:grid-cols-3 gap-6 mb-12">
        <div class="bg-gradient-to-br from-blue-50 to-blue-100 p-6 rounded-xl text-center">
          <div class="w-12 h-12 bg-[#0A1F7A] rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-[NotoSansBold] text-[#0A1F7A] mb-2">Email</h3>
          <p class="text-sm font-[NotoSansLight] text-gray-700">contato@maiaseguros.com.br</p>
        </div>

        <div class="bg-gradient-to-br from-green-50 to-green-100 p-6 rounded-xl text-center">
          <div class="w-12 h-12 bg-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-[NotoSansBold] text-[#0A1F7A] mb-2">Telefone</h3>
          <p class="text-sm font-[NotoSansLight] text-gray-700">+62 983 303000</p>
        </div>

        <div class="bg-gradient-to-br from-purple-50 to-purple-100 p-6 rounded-xl text-center">
          <div class="w-12 h-12 bg-purple-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-[NotoSansBold] text-[#0A1F7A] mb-2">WhatsApp</h3>
          <p class="text-sm font-[NotoSansLight] text-gray-700">+62 983 303000</p>
        </div>
      </div>

      {/* Formulário */}
      <div id="formulario">
        <FormContainer client:load/>
      </div>

    </div>
  </div>
</Layout>